{
  "is-c3-addon": true,
  "sdk-version": 2,
  "type": "effect",
  "name": "Volumetric Spotlight",
  "id": "mikal-volumetric-spot-v1",
  "version": "1.0.0.0",
  "author": "Mikal",
  "website": "https://www.construct.net",
  "documentation": "https://www.construct.net",
  "description": "Volumetric spotlight scatter effect using ray marching",
  "file-list": [
    "lang/en-US.json",
    "addon.json",
    "effect.webgl2.fx",
    "effect.wgsl"
  ],
  "category": "color",
  "blends-background": false,
  "uses-depth": true,
  "cross-sampling": false,
  "preserves-opaqueness": false,
  "animated": true,
  "must-predraw": false,
  "extend-box": { "horizontal": 0, "vertical": 0 },
  "is-deprecated": false,
  "supported-renderers": ["webgl2", "webgpu"],
  "supports-3d-direct-rendering": true,
  "parameters": [
    { "id": "cam-x",           "type": "float", "initial-value": 0,        "uniform": "camX" },
    { "id": "cam-y",           "type": "float", "initial-value": 0,        "uniform": "camY" },
    { "id": "cam-z",           "type": "float", "initial-value": -500,     "uniform": "camZ" },
    { "id": "cam-look-x",     "type": "float", "initial-value": 0,        "uniform": "camLookX" },
    { "id": "cam-look-y",     "type": "float", "initial-value": 0,        "uniform": "camLookY" },
    { "id": "cam-look-z",     "type": "float", "initial-value": 0,        "uniform": "camLookZ" },
    { "id": "cam-fov",        "type": "float", "initial-value": 0.7854,   "uniform": "camFov" },
    { "id": "cam-up-x", "type": "float", "initial-value": 0,        "uniform": "camLookUpX" },
    { "id": "cam-up-y", "type": "float", "initial-value": -1,       "uniform": "camLookUpY" },
    { "id": "cam-up-z", "type": "float", "initial-value": 0,        "uniform": "camLookUpZ" },
    { "id": "light1-x",       "type": "float", "initial-value": 0,        "uniform": "light1X" },
    { "id": "light1-y",       "type": "float", "initial-value": -200,     "uniform": "light1Y" },
    { "id": "light1-z",       "type": "float", "initial-value": 0,        "uniform": "light1Z" },
    { "id": "light1-dir-x",   "type": "float", "initial-value": 0,        "uniform": "light1DirX" },
    { "id": "light1-dir-y",   "type": "float", "initial-value": 1,        "uniform": "light1DirY" },
    { "id": "light1-dir-z",   "type": "float", "initial-value": 0,        "uniform": "light1DirZ" },
    { "id": "light1-color",   "type": "color",  "initial-value": [1, 1, 1], "uniform": "light1Color" },
    { "id": "light1-intensity","type": "float", "initial-value": 1,        "uniform": "light1Intensity" },
    { "id": "light1-cone-angle","type": "float","initial-value": 0.866,    "uniform": "light1ConeAngle" },
    { "id": "light1-cone-edge","type": "float", "initial-value": 0.1,      "uniform": "light1ConeEdge" },
    { "id": "light1-atten-c", "type": "float", "initial-value": 0,        "uniform": "light1AttenC" },
    { "id": "light1-atten-l", "type": "float", "initial-value": 0.01,     "uniform": "light1AttenL" },
    { "id": "light1-atten-q", "type": "float", "initial-value": 0.0001,   "uniform": "light1AttenQ" },
    { "id": "light1-dust",   "type": "float", "initial-value": 0.5,      "uniform": "light1Dust" },
    { "id": "light1-dust-count","type": "float","initial-value": 0.005,   "uniform": "light1DustCount" },
    { "id": "light1-dust-speed","type": "float","initial-value": 0.003,   "uniform": "light1DustSpeed" },
    { "id": "light1-dust-fade","type": "float","initial-value": 0.003,   "uniform": "light1DustFade" },
    { "id": "light1-dust-drift","type": "float","initial-value": 0.5,   "uniform": "light1DustDrift" },
    { "id": "debug-mode",    "type": "float", "initial-value": 0,        "uniform": "debugMode" }
  ]
}
